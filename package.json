    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "pg": "^8.13.1",
