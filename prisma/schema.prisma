generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            BigInt            @id @default(autoincrement())
  name          String            @db.VarChar(100)
  email         String            @unique @db.VarChar(150)
  passwordHash  String            @map("password_hash") @db.Text
  role          String            @default("user") @db.VarChar(20)
  avatarUrl     String?           @map("avatar_url") @db.Text
  phone         String?           @db.VarChar(30)
  isActive      Boolean           @default(true) @map("is_active")
  lastLoginAt   DateTime?         @map("last_login_at") @db.Timestamptz
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  submittedPlaces      Place[]              @relation("SubmittedPlaces")
  approvedPlaces       Place[]              @relation("ApprovedPlaces")
  placePhotos          PlacePhoto[]         @relation("UploadedPhotos")
  approvedPhotos       PlacePhoto[]         @relation("ApprovedPhotos")
  reviews              Review[]
  approvedReviews      Review[]             @relation("ApprovedReviews")
  favorites            Favorite[]
  recommendations      PlaceRecommendation[]
  editRequests         PlaceEditRequest[]
  reviewedEditRequests PlaceEditRequest[]   @relation("ReviewedEditRequests")
  reports              Report[]
  resolvedReports      Report[]             @relation("ResolvedReports")
  moderationLogs       ModerationLog[]
  updatedSettings      AppSettings[]        @relation("UpdatedBy")

  @@map("users")
}

model AppSettings {
  id                    BigInt   @id @default(autoincrement())
  placeApprovalMode     String   @default("manual") @map("place_approval_mode") @db.VarChar(20)
  reviewApprovalMode    String   @default("auto") @map("review_approval_mode") @db.VarChar(20)
  photoApprovalMode     String   @default("manual") @map("photo_approval_mode") @db.VarChar(20)
  allowUserPlaceSubmission Boolean @default(true) @map("allow_user_place_submission")
  allowUserReviews      Boolean  @default(true) @map("allow_user_reviews")
  updatedBy             BigInt?  @map("updated_by")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  updatedByUser User? @relation("UpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("app_settings")
}

model Category {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(80)
  slug        String   @unique @db.VarChar(100)
  icon        String?  @db.VarChar(100)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  places Place[]

  @@map("categories")
}

model Tag {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(80)
  slug      String   @unique @db.VarChar(100)
  type      String   @db.VarChar(20)
  icon      String?  @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  placeTags PlaceTag[]

  @@map("tags")
}

model Place {
  id                    BigInt   @id @default(autoincrement())
  categoryId            BigInt   @map("category_id")
  submittedBy           BigInt?  @map("submitted_by")
  approvedBy            BigInt?  @map("approved_by")
  duplicateOfPlaceId    BigInt?  @map("duplicate_of_place_id")
  name                  String   @db.VarChar(150)
  slug                  String   @unique @db.VarChar(180)
  description           String?  @db.Text
  address               String   @db.Text
  district              String?  @db.VarChar(100)
  subdistrict           String?  @db.VarChar(100)
  city                  String   @default("Surabaya") @db.VarChar(100)
  postalCode            String?  @map("postal_code") @db.VarChar(20)
  latitude              Decimal  @db.Decimal(10, 7)
  longitude             Decimal  @db.Decimal(10, 7)
  mapPinVerified        Boolean  @default(false) @map("map_pin_verified")
  lastVerifiedAt        DateTime? @map("last_verified_at") @db.Timestamptz
  priceMin              Int?     @map("price_min")
  priceMax              Int?     @map("price_max")
  phone                 String?  @db.VarChar(30)
  websiteUrl            String?  @map("website_url") @db.Text
  instagramUrl          String?  @map("instagram_url") @db.Text
  googleMapsUrl         String?  @map("google_maps_url") @db.Text
  coverPhotoUrl         String?  @map("cover_photo_url") @db.Text
  avgRating             Decimal  @default(0) @map("avg_rating") @db.Decimal(3, 2)
  ratingCount           Int      @default(0) @map("rating_count")
  favoriteCount         Int      @default(0) @map("favorite_count")
  recommendationCount   Int      @default(0) @map("recommendation_count")
  reportCount           Int      @default(0) @map("report_count")
  status                String   @default("pending") @db.VarChar(20)
  approvedVia           String?  @map("approved_via") @db.VarChar(20)
  rejectionReason       String?  @map("rejection_reason") @db.Text
  isPermanentlyClosed   Boolean  @default(false) @map("is_permanently_closed")
  submittedAt           DateTime @default(now()) @map("submitted_at") @db.Timestamptz
  reviewedAt            DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  category       Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  submitter      User?                @relation("SubmittedPlaces", fields: [submittedBy], references: [id], onDelete: SetNull)
  approver       User?                @relation("ApprovedPlaces", fields: [approvedBy], references: [id], onDelete: SetNull)
  duplicateOf    Place?               @relation("PlaceDuplicates", fields: [duplicateOfPlaceId], references: [id], onDelete: SetNull)
  duplicates     Place[]              @relation("PlaceDuplicates")
  placeTags      PlaceTag[]
  openingHours   OpeningHour[]
  photos         PlacePhoto[]
  reviews        Review[]
  favorites      Favorite[]
  recommendations PlaceRecommendation[]
  editRequests   PlaceEditRequest[]
  reports        Report[]

  @@map("places")
}

model PlaceTag {
  placeId   BigInt   @map("place_id")
  tagId     BigInt   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([placeId, tagId])
  @@map("place_tags")
}

model OpeningHour {
  id           BigInt   @id @default(autoincrement())
  placeId      BigInt   @map("place_id")
  dayOfWeek    Int      @map("day_of_week")
  openTime     DateTime? @map("open_time") @db.Time
  closeTime    DateTime? @map("close_time") @db.Time
  isClosed     Boolean  @default(false) @map("is_closed")
  is24Hours    Boolean  @default(false) @map("is_24_hours")
  spansNextDay Boolean  @default(false) @map("spans_next_day")
  note         String?  @db.VarChar(150)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, dayOfWeek])
  @@map("opening_hours")
}

model PlacePhoto {
  id             BigInt   @id @default(autoincrement())
  placeId        BigInt   @map("place_id")
  uploadedBy     BigInt?  @map("uploaded_by")
  photoUrl       String   @map("photo_url") @db.Text
  storagePath    String?  @map("storage_path") @db.Text
  caption        String?  @db.VarChar(150)
  isCover        Boolean  @default(false) @map("is_cover")
  status         String   @default("pending") @db.VarChar(20)
  approvedBy     BigInt?  @map("approved_by")
  approvedVia    String?  @map("approved_via") @db.VarChar(20)
  rejectionReason String? @map("rejection_reason") @db.Text
  reviewedAt     DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  place      Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  uploader   User? @relation("UploadedPhotos", fields: [uploadedBy], references: [id], onDelete: SetNull)
  approver   User? @relation("ApprovedPhotos", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@map("place_photos")
}

model Review {
  id             BigInt   @id @default(autoincrement())
  placeId        BigInt   @map("place_id")
  userId         BigInt   @map("user_id")
  rating         Int
  comment        String?  @db.Text
  status         String   @default("pending") @db.VarChar(20)
  approvedBy     BigInt?  @map("approved_by")
  approvedVia    String?  @map("approved_via") @db.VarChar(20)
  rejectionReason String? @map("rejection_reason") @db.Text
  reviewedAt     DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  place    Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("ApprovedReviews", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@unique([placeId, userId])
  @@map("reviews")
}

model Favorite {
  userId    BigInt   @map("user_id")
  placeId   BigInt   @map("place_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
  @@map("favorites")
}

model PlaceRecommendation {
  userId    BigInt   @map("user_id")
  placeId   BigInt   @map("place_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
  @@map("place_recommendations")
}

model PlaceEditRequest {
  id           BigInt   @id @default(autoincrement())
  placeId      BigInt   @map("place_id")
  submittedBy  BigInt   @map("submitted_by")
  proposedData Json     @map("proposed_data")
  status       String   @default("pending") @db.VarChar(20)
  reviewedBy   BigInt?  @map("reviewed_by")
  reviewNote   String?  @map("review_note") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  reviewedAt   DateTime? @map("reviewed_at") @db.Timestamptz

  place   Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  submitter User @relation(fields: [submittedBy], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedEditRequests", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("place_edit_requests")
}

model Report {
  id            BigInt   @id @default(autoincrement())
  placeId       BigInt   @map("place_id")
  reportedBy    BigInt   @map("reported_by")
  reasonType    String   @map("reason_type") @db.VarChar(30)
  description   String?  @db.Text
  status        String   @default("open") @db.VarChar(20)
  resolvedBy    BigInt?  @map("resolved_by")
  resolutionNote String? @map("resolution_note") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz

  place    Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  reporter User  @relation(fields: [reportedBy], references: [id], onDelete: Cascade)
  resolver User? @relation("ResolvedReports", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@map("reports")
}

model ModerationLog {
  id         BigInt   @id @default(autoincrement())
  adminId    BigInt?  @map("admin_id")
  targetType String   @map("target_type") @db.VarChar(30)
  targetId   BigInt   @map("target_id")
  action     String   @db.VarChar(30)
  note       String?  @db.Text
  beforeData Json?    @map("before_data")
  afterData  Json?    @map("after_data")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  admin User? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@map("moderation_logs")
}
